# Modelo de configuração de credenciais do FatFlow.
# Copie este arquivo para data/.env e preencha os valores reais.
# ATENÇÃO: data/.env NÃO deve ser versionado (está no .gitignore).
# O data/.env.encrypted é gerado automaticamente no build (pyinstaller FatFlow.spec).
#
# Formato: CHAVE = valor   (sem aspas)
#
# Opcional: em vez de embutir a chave no build, voce pode definir a variavel de
# ambiente do sistema FATFLOW_KEY na maquina do usuario. Se definida, ela tem
# prioridade sobre a FIXED_KEY abaixo.

# Chave Fernet usada para (de)criptografar o .env.encrypted.
# Gere uma nova com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIXED_KEY = sua_chave_fernet_aqui

# Login de acesso ao proprio app FatFlow
APP_LOGIN = usuario_do_app
APP_PASSWORD = senha_do_app

URL_GUIA_FASE = http://SEU_HOST/

# Token do ambiente de homologacao/QAS
X-TOKEN = seu_token_jwt_qas_aqui

# Token do ambiente de PRODUCAO
X-TOKEN-PROD = seu_token_jwt_prod_aqui

LOGIN_OOBJ = usuario.oobj
SENHA_OOBJ = senha_oobj

USERNAME_SS = usuario@email.com
PASS_SS = senha_softsul
